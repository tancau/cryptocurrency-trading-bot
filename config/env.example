# ======================================================================
# ============ Environment Configuration Template (环境变量配置模板)
# 请将此文件复制到 ~/.bashrc 或当前会话使用
# ======================================================================

# === Binance API Keys (API 密钥配置) ===
# ⚠️ 重要提示：
#   - Testnet: 从 https://testnet.binancefuture.com/ 获取
#   - Live: 从 https://www.binance.com/en/profile 获取（生产环境）
# ======================================================================

# Binance API 密钥
export BINANCE_API_KEY='your_real_key_here'              # 👉 替换为你的真实密钥或占位符
export BINANCE_API_SECRET='your_real_secret_here'        # 👉 替换为你的真实密钥或占位符

# === Testnet Configuration (测试网络配置) ===
export BINANCE_TESTNET_MODE=false                         # ✅ false=生产环境 | true=测试环境
export TESTNET_API_URL=https://testnet.binancefuture.com/api/v3
export TESTNET_WS_URL=wss://stream-testnet.binancefuture.com/stream

# === Trading Parameters (交易参数配置) ===
export STARTUP_CAPITAL=1000.0                             # 💰 初始资金（USDT）
export TRADING_ENABLED=true                                # 🔔 启用自动交易 | false=仅监控
export LEVERAGE_MAX=3x                                     # ⚠️ 最大杠杆倍数

# === Risk Management (风险管理配置) ===
export MAX_POSITION_SIZE=10                               # 单笔最大持仓（USDT）
export STOP_LOSS_PERCENTAGE=5.0                           # 止损百分比（%）
export TAKE_PROFIT_PERCENTAGE=3.0                         # 止盈百分比（%）
export DAILY_LIMIT_PCT=20                                  # 每日亏损上限（%）

# === Telegram Alerts (Telegram 警报配置) ===
export TELEGRAM_BOT_TOKEN=''                               # 👉 创建 Bot 后填入 token
export TELEGRAM_CHAT_ID=''                                 # 👉 获取 Chat ID 后填入
export ALERT_ON_STOP_LOSS=true                             # 📊 止损触发时发送警报
export ALERT_ON_TAKE_PROFIT=true                           # 📊 止盈达成时发送警报
export ALERT_ON_SYSTEM_ERROR=true                          # ⚠️ 系统异常时发送警报

# === Logging Configuration (日志配置) ===
export LOG_LEVEL='INFO'                                    # 🔍 DEBUG=调试 | INFO=正常 | WARNING=警告
export LOG_FILE='/home/tancau/.openclaw/workspace/skills/cryptocurrency-trading/logs/trading.log'
export LOG_ROTATION_DAYS=7                                 # 🔄 保留天数

# === Market Configuration (市场配置) ===
export MARKETS_BTC=true                                     # ✅ BTC/USDT
export MARKETS_ETH=true                                     # ✅ ETH/USDT
export MARKETS_BNB=true                                     # ✅ BNB/USDT
export MARKETS_SOL=true                                     # ✅ SOL/USDT
export MONITOR_INTERVAL=60                                  # 🕐 监控间隔（秒）

# === System Settings (系统设置) ===
export PYTHONUNBUFFERED=1                                   # 🐍 Python 不缓冲输出
export PYTHONDONTWRITEBYTECODE=1                            # 📁 不生成.pyc 文件

# ======================================================================
# ============ Quick Start Guide (快速启动指南)
# ======================================================================
#
# Step 1: 设置环境变量
#   export $(grep -v '^#' ~/.bash_profile | xargs)
#
# Step 2: 安装依赖包
#   ./install_dependencies.sh
#
# Step 3: 启动服务（Systemd）
#   sudo systemctl enable trading.timer
#   sudo systemctl start trading.service
#
# Step 4: 监控日志
#   tail -f logs/trading.log
#
# ======================================================================
